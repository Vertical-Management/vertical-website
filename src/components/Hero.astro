---
// Hero component as pure Astro (static HTML)
const BASE_URL = import.meta.env.BASE_URL;
const basePrefix = BASE_URL.endsWith('/') ? BASE_URL : `${BASE_URL}/`;

const withBase = (path) => `${basePrefix}${path.replace(/^\/+/, '')}`;
---
<section class="hero">
  <div class="hero-media">
    <img 
      src={withBase('assets/1. PAG DE ENTRADA/PORTFOLIO 2026.gif')} 
      alt="Impact portfolio Vertical Management"
      loading="eager"
      decoding="async"
    />
  </div>
  <div class="hero-cta">
    <a class="btn-primary" href={withBase('servicios')}>Ver servicios</a>
  </div>
</section>

<script>
  // Add entrance animation to hero image on load
  const heroImg = document.querySelector('.hero-media img');
  if (heroImg) {
    if (heroImg.complete) {
      heroImg.classList.add('loaded');
    } else {
      heroImg.addEventListener('load', () => {
        heroImg.classList.add('loaded');
      });
      
      // Fallback timeout in case loading stalls
      setTimeout(() => {
        if (!heroImg.classList.contains('loaded')) {
          heroImg.classList.add('loaded');
        }
      }, 3000);
    }
  }
</script>
