---
export interface Props {
  className?: string;
  clasName?: string;
}

const { className = '', clasName = '' } = Astro.props;
const headerClass = [className, clasName].filter(Boolean).join(' ');

const BASE_URL = import.meta.env.BASE_URL;
const basePrefix = BASE_URL.endsWith('/') ? BASE_URL : `${BASE_URL}/`;

const withBase = (path) => `${basePrefix}${path.replace(/^\/+/, '')}`;
---
<header class={`vm-header ${headerClass}`}>
  <div class="vm-container vm-header-inner">
    <a class="vm-brand" href={BASE_URL}>
      <span class="vm-brand-text">Vertical Management</span>
    </a>

    <a class="vm-logo" href={BASE_URL}>
      <img src={withBase('assets/logo/VERTICAL-BLACK.png')} alt="Vertical Management" />
    </a>

    <button
      class="vm-hamburger"
      aria-label="Toggle menu"
      aria-controls="nav-menu"
      aria-expanded="false"
      id="hamburger-menu"
    >
      <span class="bar"></span>
      <span class="bar"></span>
      <span class="bar"></span>
    </button>

    <nav class="vm-nav" id="nav-menu">
      <a href={BASE_URL}>Inicio</a>
      <a href={withBase('servicios')}>Servicios</a>
      <a href={withBase('proyectos')}>Proyectos</a>
      <a href={withBase('contacto')}>Contacto</a>
    </nav>
  </div>
</header>

<script>
  // Mobile menu toggle
  const hamburger = document.getElementById('hamburger-menu');
  const nav = document.getElementById('nav-menu');

  const setMenuOpen = (isOpen) => {
    nav?.classList.toggle('open', isOpen);
    hamburger?.setAttribute('aria-expanded', String(isOpen));
  };

  const toggleMenu = () => {
    const isOpen = nav?.classList.contains('open') ?? false;
    setMenuOpen(!isOpen);
  };
  
  hamburger?.addEventListener('click', toggleMenu);
  
  // Close menu when clicking a link
  nav?.querySelectorAll('a').forEach((link) => {
    link.addEventListener('click', () => {
      setMenuOpen(false);
    });
  });

  document.addEventListener('click', (event) => {
    if (!nav || !hamburger) return;
    const target = event.target;
    if (!(target instanceof Node)) return;

    const clickedInsideMenu = nav.contains(target) || hamburger.contains(target);
    if (!clickedInsideMenu) {
      setMenuOpen(false);
    }
  });

  document.addEventListener('keydown', (event) => {
    if (event.key === 'Escape') {
      setMenuOpen(false);
    }
  });
</script>
