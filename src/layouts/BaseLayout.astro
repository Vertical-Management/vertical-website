---
import '../styles/global.scss';
import '../styles/tailwind.css';
const { children, title = 'Vertical Management — Esteban Ferrer', isFEP = false, isCafeteros = false, isKoaj = false, isPedigree = false, showGlobalLegal = true } = Astro.props;
const BASE_URL = import.meta.env.BASE_URL;
const basePrefix = BASE_URL.endsWith('/') ? BASE_URL : `${BASE_URL}/`;

const withBase = (path) => `${basePrefix}${path.replace(/^\/+/, '')}`;
---
<!doctype html>
<html lang="es" class={`${isFEP ? 'is-fep-page' : ''} ${isCafeteros ? 'is-cafeteros-page' : ''} ${isKoaj ? 'is-koaj-page' : ''} ${isPedigree ? 'is-pedigree-page' : ''}`}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content="Portfolio de Esteban Ferrer — Vertical Management" />
    <link rel="icon" href={withBase('favicon.svg')} />
    <link rel="apple-touch-icon" href={withBase('favicon.svg')} />
  </head>
  <body style={`--xp-wallpaper-image:url('${withBase('assets/xp/windows.png')}')`}>
    <main>
      <slot />
    </main>
    {showGlobalLegal && (
      <footer class="vm-global-legal" role="contentinfo">
        <p>All rights Reserved • Copyright © 2026 Vertical Management</p>
        <p>Privacy Policy • Cookie Policy</p>
      </footer>
    )}
  </body>
</html>
