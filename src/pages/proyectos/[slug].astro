---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import FEPGallery from '../../components/FEPGallery.jsx';
import CafeterosGallery from '../../components/CafeterosGallery.jsx';
import KoajGallery from '../../components/KoajGallery.jsx';
import projects from '../../data/projects.json';

export async function getStaticPaths() {
  return projects.projects
    .map((project) => ({
    params: { slug: project.slug },
    props: { project },
  }));
}

const { project } = Astro.props;
const BASE_URL = import.meta.env.BASE_URL;
const basePrefix = BASE_URL.endsWith('/') ? BASE_URL : `${BASE_URL}/`;
const withBase = (path) => `${basePrefix}${String(path || '').replace(/^\/+/, '')}`;
const projectWithBase = project
  ? {
      ...project,
      images: project.images?.map((img) => withBase(img)),
      referenceImage: project.referenceImage ? withBase(project.referenceImage) : null,
      videoUrl: project.videoUrl ? withBase(project.videoUrl) : null,
    }
  : project;
const isFEP = project?.slug === 'fep2026-animation';
const isCafeteros = project?.slug === 'branding-cafeteros';
const isKoaj = project?.slug === 'koaj-3d';
---
<BaseLayout title={project ? `${project.title} — Vertical` : 'Proyecto'} isFEP={isFEP} isCafeteros={isCafeteros}>
  <Header />
  <section class={`project-detail vm-container ${isFEP ? 'is-fep' : ''} ${isCafeteros ? 'is-cafeteros' : ''} ${isKoaj ? 'is-koaj' : ''}`}>
    <h1>{project.title}</h1>
    {project.subtitle && <p class="project-subtitle">{project.subtitle}</p>}
    <p>{project.short}</p>
    
    {isCafeteros ? (
      <CafeterosGallery client:only="react" images={projectWithBase.images} description={project.description} referenceImage={projectWithBase.referenceImage} referenceText={project.referenceText} creationText={project.creationText} creationImagesText={project.creationImagesText} />
    ) : isKoaj ? (
      <KoajGallery client:idle images={projectWithBase.images} short={project.short} description={project.description} />
    ) : isFEP ? (
      <FEPGallery client:idle images={projectWithBase.images} description={project.description} referenceImage={projectWithBase.referenceImage} referenceText={project.referenceText} creationText={project.creationText} creationImagesText={project.creationImagesText} videoUrl={projectWithBase.videoUrl} />
    ) : (
      <div class="gallery">
        {projectWithBase.images?.map((img) => (
          <img src={img} alt={project.title} loading="eager" />
        ))}
      </div>
    )}
  </section>
</BaseLayout>
