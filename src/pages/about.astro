---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.jsx';
---
<BaseLayout title="About — Vertical Management">
  <Header />
  <section className="about vm-container">
    <h1>Sobre Esteban Ferrer</h1>
    <p>
      Soy Esteban Ferrer, diseñador multidisciplinario y fundador de Vertical Management. Trabajo creando identidades
      visuales, experiencias digitales y piezas de motion que conectan con audiencias.
    </p>
    <h2>Enfoque</h2>
    <p>
      Diseño estratégico que combina minimalismo y expresividad: una primera impresión sobria que se transforma en
      experiencias visuales ricas dentro de cada proyecto.
    </p>
  </section>
</BaseLayout>
