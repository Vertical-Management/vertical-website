---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
---
<BaseLayout title="Servicios — Vertical Management">
  <Header />
  <section class="services vm-container">
    <h1>Servicios</h1>
    <p class="section-intro">Ofrecemos soluciones integrales de diseño para potenciar tu marca</p>
    <div class="services-grid">
      <article class="service-card">
        <h2>Branding</h2>
        <p>Identidad visual, estrategia de marca, y sistemas gráficos aplicables a digital e impresión.</p>
      </article>
      <article class="service-card">
        <h2>UX / UI</h2>
        <p>Diseño de productos digitales, prototipado y pruebas de usabilidad para experiencias eficaces.</p>
      </article>
      <article class="service-card">
        <h2>Animación & Motion</h2>
        <p>Loops, videoclips y piezas animadas para presentación y redes sociales.</p>
      </article>
      <article class="service-card">
        <h2>Consultoría Visual</h2>
        <p>Asesoría estratégica para consolidar presencia visual y narrativa de marca.</p>
      </article>
    </div>
  </section>
</BaseLayout>
