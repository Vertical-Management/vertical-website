---
import BaseLayout from '../layouts/BaseLayout.astro';
import '../styles/servicios-memphis.scss';

const BASE_URL = import.meta.env.BASE_URL;
const basePrefix = BASE_URL.endsWith('/') ? BASE_URL : `${BASE_URL}/`;
const withBase = (path) => `${basePrefix}${path.replace(/^\/+/, '')}`;

const navItems = [
  { label: 'Inicio', href: '/' },
  { label: 'Servicios', href: '/servicios' },
  { label: 'Proyectos', href: '/proyectos' },
  { label: 'Contacto', href: '/contacto' },
];
const tickerTop = ['FURNITURE', 'TABLES', 'SEATS', 'BEDS', 'LIGHTS', 'OBJECTS'];
const tickerBottom = ['BEDS', 'SEATS', 'TABLES', 'FURNITURE', 'GLASS', 'TEXTILES'];

const topServices = [
  {
    title: 'Branding',
    description:
      'Identidad visual, estrategia de marca, y sistemas gráficos aplicables a digital e impresión.',
  },
  {
    title: 'UX / UI',
    description:
      'Diseño de productos digitales, prototipado y pruebas de usabilidad para experiencias eficaces.',
  },
  {
    title: 'Animación & Motion',
    description: 'Loops, videoclips y piezas animadas para presentación y redes sociales.',
  },
  {
    title: 'Consultoría Visual',
    description: 'Asesoría estratégica para consolidar presencia visual y narrativa de marca.',
  },
];

const socialLinks = [
  { label: 'NEWSLETTER', href: '/contacto', className: 'is-news' },
  { label: 'INSTAGRAM', href: 'https://instagram.com', className: 'is-instagram' },
  { label: 'FACEBOOK', href: 'https://facebook.com', className: 'is-facebook' },
  { label: 'LINKEDIN', href: 'https://linkedin.com', className: 'is-linkedin' },
];
---
<BaseLayout title="Servicios — Vertical Management">
  <section class="sv-services">
    <header class="sv-topbar">
      <div class="sv-inner">
        <a class="sv-brand" href="/" aria-label="Ir a inicio">Vertical Management</a>

        <nav class="sv-nav" aria-label="Navegación principal">
          {navItems.map((item) => (
            <a href={item.href} aria-current={item.href === '/servicios' ? 'page' : undefined}>{item.label}</a>
          ))}
        </nav>
      </div>
    </header>

    <main>
      <section class="sv-top-intro" aria-labelledby="sv-services-title">
        <div class="sv-inner">
          <h1 id="sv-services-title">Servicios</h1>
          <p>Ofrecemos soluciones integrales de diseño para potenciar tu marca</p>

          <div class="sv-top-intro-grid">
            {topServices.map((service) => (
              <article class="sv-top-intro-item">
                <h2>{service.title}</h2>
                <p>{service.description}</p>
              </article>
            ))}
          </div>
        </div>
      </section>

      <section class="sv-band sv-band-blue" aria-label="Categorías">
        <div class="sv-inner">
          <p>{tickerTop.join(' ')}</p>
          <p>{tickerBottom.join(' ')}</p>
        </div>
      </section>

      <div class="sv-pattern" aria-hidden="true"></div>

      <section class="sv-split is-yellow">
        <div class="sv-split-grid">
          <figure class="sv-media">
            <img src={withBase('assets/PAG BRANDING CAFETEROS CO/CCDC5.webp')} alt="Grupo creativo" loading="lazy" />
          </figure>

          <article class="sv-panel is-yellow">
            <h2>THE MEMPHIS GROUP</h2>
            <p>
              Un enfoque visual que mezcla disrupción, cultura y negocio para construir sistemas con identidad real.
            </p>
            <a href="/contacto">Scopri di più</a>
          </article>
        </div>
      </section>

      <section class="sv-quote is-red">
        <div class="sv-inner">
          <p>"DESIGN IS A WAY OF DISCUSSING LIFE."</p>
        </div>
      </section>

      <div class="sv-pattern is-alt" aria-hidden="true"></div>

      <section class="sv-split is-pink">
        <div class="sv-split-grid">
          <article class="sv-panel is-pink">
            <h2>MILANO<br />1981-1985</h2>
            <p>
              Creamos interfaces y relatos visuales con actitud histórica y una ejecución digital contemporánea.
            </p>
            <a href="/contacto">Scopri di più</a>
          </article>

          <figure class="sv-media">
            <img src={withBase('assets/PAG ANIMATION FEP2026/BUCLE SABRINA CARPENTER.gif')} alt="Retrato pop" loading="lazy" />
          </figure>
        </div>
      </section>

      <section class="sv-quote is-cream">
        <div class="sv-inner">
          <p>"THERE IS NO SUCH THING AS A MEMPHIS STYLE."</p>
        </div>
      </section>

      <div class="sv-pattern" aria-hidden="true"></div>

      <section class="sv-split is-red">
        <div class="sv-split-grid">
          <figure class="sv-media">
            <img src={withBase('assets/PAG KOAJ 3D/FEP KOAJ13.webp')} alt="Espacio expositivo" loading="lazy" />
          </figure>

          <article class="sv-panel is-red">
            <h2>EXHIBITIONS</h2>
            <p>
              Diseñamos presencia de marca para espacios y lanzamientos donde la narrativa visual debe impactar en
              segundos.
            </p>
            <a href="/contacto">Scopri di più</a>
          </article>
        </div>
      </section>

      <section class="sv-quote is-pink">
        <div class="sv-inner">
          <p>"I HAVE ALWAYS HAD THE SAME OBSESSION."</p>
        </div>
      </section>

      <div class="sv-pattern is-alt" aria-hidden="true"></div>

      <section class="sv-split is-orange">
        <div class="sv-split-grid">
          <figure class="sv-media">
            <img src={withBase('assets/PAG BRANDING CAFETEROS CO/CCDC6.webp')} alt="Espacio interior" loading="lazy" />
          </figure>

          <article class="sv-panel is-orange">
            <h2>THE IDEA<br />OF HOME</h2>
            <p>
              Construimos ecosistemas visuales que conectan producto, entorno y mensaje en una experiencia coherente.
            </p>
            <a href="/contacto">Discover more</a>
          </article>
        </div>
      </section>

      <section class="sv-split is-green">
        <div class="sv-split-grid">
          <article class="sv-panel is-green">
            <h2>MORE COLORFUL<br />MORE JOYFUL</h2>
            <p>
              Dirección visual integral para marcas que necesitan diferenciarse con estructura y una estética valiente.
            </p>
            <a href="/contacto">Scopri di più</a>
          </article>

          <figure class="sv-media is-white-stage">
            <img src={withBase('assets/PAG BRANDING CAFETEROS CO/PNG COFFE/CUP COFFE.webp')} alt="Producto destacado" loading="lazy" />
          </figure>
        </div>
      </section>

      <section class="sv-contact">
        <div class="sv-inner">
          <h2>MEMPHIS<br />S.R.L.</h2>
          <p>Località Batasiolo 85/A, 12064, La Morra, Italy</p>
          <p>info@vertical.management</p>
          <p>+39 0173 56102</p>
        </div>
      </section>

      <section class="sv-contact-cta">
        <div class="sv-inner">
          <a href="/contacto">Contact us →</a>
        </div>
      </section>

      <section class="sv-social" aria-label="Redes">
        <div class="sv-social-grid">
          {socialLinks.map((link) => (
            <a href={link.href} class={link.className} target={link.href.startsWith('http') ? '_blank' : undefined} rel={link.href.startsWith('http') ? 'noreferrer' : undefined}>
              {link.label}
            </a>
          ))}
        </div>
      </section>

      <footer class="sv-legal">
        <div class="sv-inner">
          <p>All rights Reserved • Copyright © 2026 Vertical Management</p>
          <p>Privacy Policy • Cookie Policy</p>
        </div>
      </footer>
    </main>
  </section>
</BaseLayout>
