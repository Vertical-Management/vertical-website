---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';

const BASE_URL = import.meta.env.BASE_URL;
const basePrefix = BASE_URL.endsWith('/') ? BASE_URL : `${BASE_URL}/`;
const withBase = (path) => `${basePrefix}${path.replace(/^\/+/, '')}`;
---
<BaseLayout title="Contacto — Vertical Management">
  <Header />
  <section class="contact vm-container">
    <header class="contact-hero">
      <p class="contact-kicker">Vertical Management</p>
      <h1>Construyamos algo que se note.</h1>
      <p class="contact-intro">
        Si valoras las ideas con intención, ejecución cuidada y obsesión por el detalle, hablemos.
        Estoy disponible para proyectos de branding, diseño digital y dirección creativa.
      </p>
      <div class="contact-hero-actions">
        <a href="mailto:esteban@vertical-management.com" class="btn-primary">Enviar email</a>
        <a href="tel:+376625303" class="contact-ghost-link">Llamar al +376 625 303</a>
      </div>
    </header>

    <div class="contact-methods" aria-label="Canales de contacto">
      <article class="contact-card contact-card-primary">
        <p class="contact-card-label">Email</p>
        <h2>Respuesta directa</h2>
        <a href="mailto:esteban@vertical-management.com">esteban@vertical-management.com</a>
      </article>

      <article class="contact-card">
        <p class="contact-card-label">Instagram</p>
        <h2>Proceso & piezas</h2>
        <a href="https://www.instagram.com/vertical_________/" target="_blank" rel="noopener noreferrer">@vertical_________</a>
      </article>

      <article class="contact-card">
        <p class="contact-card-label">LinkedIn</p>
        <h2>Perfil profesional</h2>
        <a href="https://www.linkedin.com/in/esteban-ferrer-3777521a8/" target="_blank" rel="noopener noreferrer">Esteban Ferrer</a>
      </article>

      <article class="contact-card">
        <p class="contact-card-label">X</p>
        <h2>Visión breve</h2>
        <a href="https://x.com/verticalmanagement" target="_blank" rel="noopener noreferrer">@verticalmanagement</a>
      </article>

      <article class="contact-card">
        <p class="contact-card-label">Teléfono</p>
        <h2>Andorra</h2>
        <a href="tel:+376625303">+376 625 303</a>
      </article>

      <article class="contact-card contact-card-services">
        <p class="contact-card-label">Servicios</p>
        <h2>Cómo trabajo</h2>
        <a href={withBase('servicios')} class="contact-inline-link">Ver servicios</a>
      </article>
    </div>
  </section>
</BaseLayout>
