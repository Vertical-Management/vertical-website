---
import BaseLayout from '../layouts/BaseLayout.astro';
import ContactScene from '../components/ios26/ContactScene';
import ContactDesktopScene from '../components/ios26/ContactDesktopScene';
import DynamicIsland from '../components/ios26/DynamicIsland';

const BASE_URL = import.meta.env.BASE_URL;
const basePrefix = BASE_URL.endsWith('/') ? BASE_URL : `${BASE_URL}/`;
const withBase = (path) => `${basePrefix}${path.replace(/^\/+/, '')}`;
---
<BaseLayout title="Contacto — Vertical Management">
  <section class="contact-lockscreen">
    <div class="contact-lockscreen-bg" style={`background-image:url('${withBase('assets/xp/fondo-de-pantalla.jpg')}')`}></div>
    <div class="contact-lockscreen-overlay"></div>

    <div class="contact-ios26-shell vm-container lg:hidden" aria-label="Experiencia iOS 26">
      <ContactScene client:media="(max-width: 1023px)" assetBase={basePrefix} />
    </div>

    <div class="hidden lg:block" aria-label="Experiencia iOS 26 Desktop">
      <DynamicIsland client:media="(min-width: 1024px)" baseUrl={basePrefix} currentSection="Contacto" />

      <div class="vm-container contact-ios26-desktop-shell">
        <ContactDesktopScene client:media="(min-width: 1024px)" assetBase={basePrefix} />
      </div>
    </div>
  </section>
</BaseLayout>
