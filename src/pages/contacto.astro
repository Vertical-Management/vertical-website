---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';

const BASE_URL = import.meta.env.BASE_URL;
const basePrefix = BASE_URL.endsWith('/') ? BASE_URL : `${BASE_URL}/`;
const withBase = (path) => `${basePrefix}${path.replace(/^\/+/, '')}`;
---
<BaseLayout title="Contacto — Vertical Management">
  <Header />
  <section class="contact vm-container">
    <h1>Contacto</h1>
    <p>
      ¿Tienes un proyecto en mente? Me encantaría saber de ti. Ponte en contacto y conversemos
      sobre cómo puedo ayudarte a llevar tu visión a la realidad.
    </p>
    
    <div class="contact-methods">
      <div>
        <h3>Email</h3>
        <p><a href="mailto:esteban@vertical-management.com" target="_blank">esteban@vertical-management.com</a></p>
      </div>
      
      <div>
        <h3>Redes Sociales</h3>
        <p>
          Encuéntrame en
          <a href="#">Instagram</a> •
          <a href="#">Linkedin</a> •
          <a href="#">Twitter</a>
        </p>
      </div>
      
      <div>
        <h3>Otra Forma</h3>
        <p><a href={withBase('servicios')} class="btn-primary">Ver Servicios</a></p>
      </div>
    </div>
  </section>
</BaseLayout>
