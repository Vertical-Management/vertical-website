---
import BaseLayout from '../layouts/BaseLayout.astro';
import Minesweeper from '../components/Minesweeper.jsx';
import projects from '../data/projects.json';
import fs from 'node:fs';
import { fileURLToPath } from 'node:url';

const BASE_URL = import.meta.env.BASE_URL;
const basePrefix = BASE_URL.endsWith('/') ? BASE_URL : `${BASE_URL}/`;
const withBase = (path) => `${basePrefix}${encodeURI(String(path ?? '').replace(/^\/+/, ''))}`;

// NOTE: Official Windows XP icons are copyrighted by Microsoft.
// This page supports using *your* official icon files if you provide them under /public/assets/xp/official/.
// If an official icon is missing, we gracefully fall back to existing assets.
const publicAssetPath = (assetPath) => {
  const normalized = assetPath.replace(/^\/+/, '');
  return fileURLToPath(new URL(`../../public/${normalized}`, import.meta.url));
};

const publicAssetExists = (assetPath) => {
  try {
    return fs.existsSync(publicAssetPath(assetPath));
  } catch {
    return false;
  }
};

const pickFirstExistingAsset = (assetPaths) => {
  if (!Array.isArray(assetPaths)) return null;
  for (const assetPath of assetPaths) {
    if (assetPath && publicAssetExists(assetPath)) return assetPath;
  }
  return null;
};

const PROJECT_ICON_SOURCES = {
  'fep2026-animation': {
    official: ['assets/xp/official/fep-media-player.png', 'assets/xp/official/wmplayer.ico', 'assets/xp/official/wmplayer.png'],
    fallback: 'assets/xp/calendar.png',
  },
  'branding-cafeteros': {
    official: ['assets/xp/official/branding-cafeteros.png', 'assets/xp/official/mspaint.ico', 'assets/xp/official/mspaint.png'],
    fallback: 'assets/xp/internet.png',
  },
  'koaj-3d': {
    official: ['assets/xp/official/koaj-3d.png'],
    fallback: 'assets/xp/linux-penguin.svg',
  },
  'ux-pedigree': {
    official: ['assets/xp/official/ux-pedigree.png', 'assets/xp/official/minesweeper.ico', 'assets/xp/official/minesweeper.png'],
    fallback: 'assets/xp/minesweeper.svg',
  },
};

const getProjectIcon = (slug) => {
  const source = PROJECT_ICON_SOURCES[slug];
  if (!source) return withBase('assets/xp/notepad.png');
  const officialAsset = pickFirstExistingAsset(source.official);
  if (officialAsset) return withBase(officialAsset);
  return withBase(source.fallback);
};

const getProjectIconFallback = (slug) => {
  const source = PROJECT_ICON_SOURCES[slug];
  if (!source) return withBase('assets/xp/notepad.png');
  return withBase(source.fallback);
};

const OFFICIAL_MINESWEEPER_ICON_PATHS = ['assets/xp/official/mina.png', 'assets/xp/official/minesweeper.ico', 'assets/xp/official/minesweeper.png'];
const FALLBACK_MINESWEEPER_ICON_PATH = 'assets/xp/minesweeper.svg';
const minesweeperOfficial = pickFirstExistingAsset(OFFICIAL_MINESWEEPER_ICON_PATHS);
const MINESWEEPER_ICON = minesweeperOfficial ? withBase(minesweeperOfficial) : withBase(FALLBACK_MINESWEEPER_ICON_PATH);
const FALLBACK_MINESWEEPER_ICON = withBase(FALLBACK_MINESWEEPER_ICON_PATH);
const PROJECTS_WINDOW_ICON_PATHS = ['assets/xp/official/proyectos-banner.png'];
const FALLBACK_PROJECTS_WINDOW_ICON_PATH = 'assets/xp/folder.png';
const projectsWindowOfficial = pickFirstExistingAsset(PROJECTS_WINDOW_ICON_PATHS);
const PROJECTS_WINDOW_ICON = projectsWindowOfficial ? withBase(projectsWindowOfficial) : withBase(FALLBACK_PROJECTS_WINDOW_ICON_PATH);
const FALLBACK_PROJECTS_WINDOW_ICON = withBase(FALLBACK_PROJECTS_WINDOW_ICON_PATH);
const START_BUTTON_ICON_PATHS = ['assets/xp/official/proyectos-banner.png'];
const FALLBACK_START_BUTTON_ICON_PATH = 'assets/xp/windows.png';
const startButtonOfficial = pickFirstExistingAsset(START_BUTTON_ICON_PATHS);
const START_BUTTON_ICON = startButtonOfficial ? withBase(startButtonOfficial) : withBase(FALLBACK_START_BUTTON_ICON_PATH);
const FALLBACK_START_BUTTON_ICON = withBase(FALLBACK_START_BUTTON_ICON_PATH);
const TASKBAR_GIRL_GIF_PATHS = ['assets/xp/official/GIRL.gif'];
const FALLBACK_TASKBAR_GIRL_GIF_PATH = 'assets/xp/windows.png';
const taskbarGirlGifOfficial = pickFirstExistingAsset(TASKBAR_GIRL_GIF_PATHS);
const TASKBAR_GIRL_GIF = taskbarGirlGifOfficial ? withBase(taskbarGirlGifOfficial) : withBase(FALLBACK_TASKBAR_GIRL_GIF_PATH);
const FALLBACK_TASKBAR_GIRL_GIF = withBase(FALLBACK_TASKBAR_GIRL_GIF_PATH);
const VERTICAL_AD_IMAGE = withBase('assets/xp/vertical-ad.png');
const XP_SHORTCUTS = [
  { label: 'Inicio', icon: withBase('assets/xp/internet.png'), type: 'link', href: withBase('') },
  { label: 'Servicios', icon: withBase('assets/xp/official/shortcut-servicios.png'), type: 'link', href: withBase('servicios') },
  { label: 'Proyectos', icon: withBase('assets/xp/official/shortcut-proyectos.png'), type: 'window', target: 'projects' },
  { label: 'Contacto', icon: withBase('assets/xp/official/shortcut-contacto.png'), type: 'link', href: withBase('contacto') },
];

---

<BaseLayout title="Proyectos — Windows XP Luna">
  <div class="xp-shell">
    <section class="xp-desktop-area" aria-label="Escritorio Windows XP">
      <div class="xp-desktop-icons" role="list">
        <button type="button" class="xp-desktop-icon" role="listitem" data-open-window="mines" data-desktop-icon>
          <img
            src={MINESWEEPER_ICON}
            data-fallback-src={FALLBACK_MINESWEEPER_ICON}
            onerror="this.onerror=null;this.src=this.dataset.fallbackSrc;"
            alt="Icono Buscaminas"
            loading="lazy"
          />
          <span>Buscaminas</span>
        </button>
      </div>

      <div class="xp-top-shortcuts" aria-label="Accesos rápidos">
        {XP_SHORTCUTS.map((shortcut) => (
          shortcut.type === 'window' ? (
            <button
              type="button"
              class="xp-top-shortcut"
              data-open-window={shortcut.target}
              aria-label={shortcut.label}
            >
              <img src={shortcut.icon} alt="" loading="lazy" />
              <span>{shortcut.label}</span>
            </button>
          ) : (
            <a class="xp-top-shortcut" href={shortcut.href} aria-label={shortcut.label}>
              <img src={shortcut.icon} alt="" loading="lazy" />
              <span>{shortcut.label}</span>
            </a>
          )
        ))}
      </div>

      <section class="xp-window" data-window="projects" aria-label="Ventana Mis Proyectos" data-task-label="Mis Proyectos">
        <header class="xp-titlebar">
          <div class="xp-title-left">
            <img class="xp-title-icon" src={PROJECTS_WINDOW_ICON} data-fallback-src={FALLBACK_PROJECTS_WINDOW_ICON} onerror="this.onerror=null;this.src=this.dataset.fallbackSrc;" alt="" />
            <span class="xp-title-text">Mis Proyectos</span>
          </div>
          <div class="xp-title-buttons" aria-hidden="true">
            <button type="button" class="xp-btn xp-btn-min" data-win-action="min">_</button>
            <button type="button" class="xp-btn xp-btn-max" data-win-action="max">□</button>
            <button type="button" class="xp-btn xp-btn-close" data-win-action="close">✕</button>
          </div>
        </header>

        <div class="xp-window-content xp-window-content-projects">
          <div class="project-grid xp-window-grid">
            {projects.projects.map((p) => (
              <article class="project-card xp-window-item" key={p.slug}>
                <a href={withBase(`proyectos/${p.slug}`)}>
                  <img
                    src={getProjectIcon(p.slug)}
                    data-fallback-src={getProjectIconFallback(p.slug)}
                    onerror="this.onerror=null;this.src=this.dataset.fallbackSrc;"
                    alt={`Icono del proyecto ${p.title}`}
                    loading="lazy"
                  />
                  <h2>{p.title}</h2>
                </a>
              </article>
            ))}
          </div>
        </div>
      </section>

      <section class="xp-window" data-window="mines" aria-label="Ventana Buscaminas" data-task-label="Buscaminas">
        <header class="xp-titlebar">
          <div class="xp-title-left">
            <img class="xp-title-icon" src={MINESWEEPER_ICON} data-fallback-src={FALLBACK_MINESWEEPER_ICON} onerror="this.onerror=null;this.src=this.dataset.fallbackSrc;" alt="" />
            <span class="xp-title-text">Buscaminas</span>
          </div>
          <div class="xp-title-buttons" aria-hidden="true">
            <button type="button" class="xp-btn xp-btn-min" data-win-action="min">_</button>
            <button type="button" class="xp-btn xp-btn-max" data-win-action="max">□</button>
            <button type="button" class="xp-btn xp-btn-close" data-win-action="close">✕</button>
          </div>
        </header>

        <div class="xp-window-content xp-window-content-mines">
          <Minesweeper client:load />
        </div>
      </section>
    </section>

    <footer class="taskbar" aria-label="Barra de tareas">
      <button type="button" class="start-btn" id="start-button" aria-controls="xp-start-ad" aria-expanded="false">
        <img class="start-logo" src={START_BUTTON_ICON} data-fallback-src={FALLBACK_START_BUTTON_ICON} onerror="this.onerror=null;this.src=this.dataset.fallbackSrc;" alt="" loading="lazy" />
      </button>
      <div class="taskbar-windows" id="taskbar-windows" aria-label="Ventanas abiertas"></div>
      <div class="taskbar-clock-wrap">
        <img class="taskbar-girl-gif" src={TASKBAR_GIRL_GIF} data-fallback-src={FALLBACK_TASKBAR_GIRL_GIF} onerror="this.onerror=null;this.src=this.dataset.fallbackSrc;" alt="Girl dancing" loading="lazy" />
        <div class="taskbar-clock" id="taskbar-clock">12:00 PM</div>
      </div>
    </footer>

    <div class="xp-ad-backdrop" id="xp-start-ad" hidden>
      <section class="xp-window xp-ad-modal" role="dialog" aria-modal="true" aria-labelledby="xp-ad-title">
        <header class="xp-titlebar">
          <div class="xp-title-left">
            <img
              class="xp-title-icon"
              src={START_BUTTON_ICON}
              data-fallback-src={FALLBACK_START_BUTTON_ICON}
              onerror="this.onerror=null;this.src=this.dataset.fallbackSrc;"
              alt=""
              loading="lazy"
            />
            <span class="xp-title-text" id="xp-ad-title">Oferta de Internet Explorer</span>
          </div>
          <div class="xp-title-buttons">
            <button type="button" class="xp-btn xp-btn-close" id="xp-ad-close" aria-label="Cerrar anuncio">✕</button>
          </div>
        </header>
        <div class="xp-window-content xp-ad-body">
          <img class="xp-ad-image" src={VERTICAL_AD_IMAGE} alt="Banner publicitario de Vertical Management" loading="lazy" />
          <p class="xp-ad-kicker">!!! NUEVO !!!</p>
          <p>¡Has tenido suerte! ✨</p>
          <p>Ahora puedes contratarme y subir de nivel tus proyectos.</p>
        </div>
        <div class="xp-ad-actions">
          <a href={withBase('contacto')} class="xp-ad-action">Contratar ahora</a>
          <button type="button" class="xp-ad-action" id="xp-ad-ok">Cerrar</button>
        </div>
      </section>
    </div>
  </div>

  <script>
    document.addEventListener('DOMContentLoaded', () => {
      const desktopArea = document.querySelector('.xp-desktop-area');
      const windowEls = Array.from(document.querySelectorAll('.xp-window[data-window]'));
      const desktopIcons = Array.from(document.querySelectorAll('[data-desktop-icon]'));
      const openWindowButtons = Array.from(document.querySelectorAll('[data-open-window]'));
      const taskbarWindows = document.getElementById('taskbar-windows');
      const clock = document.getElementById('taskbar-clock');
      const startButton = document.getElementById('start-button');
      const startAd = document.getElementById('xp-start-ad');
      const adModal = startAd?.querySelector('.xp-ad-modal');
      const adTitleBar = adModal?.querySelector('.xp-titlebar');
      const adImage = adModal?.querySelector('.xp-ad-image');
      const closeAdButton = document.getElementById('xp-ad-close');
      const closeAdOkButton = document.getElementById('xp-ad-ok');

      const installImageFallbacks = () => {
        const imgs = Array.from(document.querySelectorAll('img[data-fallback-src]'));
        imgs.forEach((img) => {
          img.addEventListener(
            'error',
            () => {
              const fallback = img.getAttribute('data-fallback-src');
              if (!fallback) return;
              if (img.getAttribute('src') === fallback) return;
              img.setAttribute('src', fallback);
            },
            { once: true }
          );
        });
      };

      installImageFallbacks();

      let zCounter = 50;
      let activeWindowId = null;
      const dragState = {
        active: false,
        windowId: null,
        pointerId: null,
        offsetX: 0,
        offsetY: 0,
      };
      const adDragState = {
        active: false,
        pointerId: null,
        offsetX: 0,
        offsetY: 0,
      };

      const getWindowById = (windowId) => windowEls.find((windowEl) => windowEl.dataset.window === windowId);
        const isStartAdOpen = () => Boolean(startAd && !startAd.hidden);
        const getOpenWindows = () => windowEls.filter((windowEl) => !windowEl.classList.contains('is-closed'));
        const getVisibleWindows = () => getOpenWindows().filter((windowEl) => !windowEl.classList.contains('is-minimized'));
        const getTopVisibleWindow = () => getVisibleWindows().sort((leftWindow, rightWindow) => Number(rightWindow.style.zIndex || '0') - Number(leftWindow.style.zIndex || '0'))[0] ?? null;

      const getWindowBounds = () => {
        const taskbarHeight = document.querySelector('.taskbar')?.offsetHeight || 0;
        const topInset = 8;
        const leftInset = 8;
        const rightInset = 8;
        const bottomInset = 8 + taskbarHeight;
        return { topInset, leftInset, rightInset, bottomInset };
      };

      const setWindowPosition = (windowEl, left, top) => {
        if (!windowEl || !desktopArea) return;
        const areaRect = desktopArea.getBoundingClientRect();
        const bounds = getWindowBounds();

        const minLeft = bounds.leftInset;
        const minTop = bounds.topInset;
        const maxLeft = Math.max(minLeft, areaRect.width - windowEl.offsetWidth - bounds.rightInset);
        const maxTop = Math.max(minTop, areaRect.height - windowEl.offsetHeight - bounds.bottomInset);

        const clampedLeft = Math.min(Math.max(minLeft, left), maxLeft);
        const clampedTop = Math.min(Math.max(minTop, top), maxTop);

        windowEl.style.left = `${clampedLeft}px`;
        windowEl.style.top = `${clampedTop}px`;
      };

      const centerWindow = (windowEl, offset = 0) => {
        if (!windowEl || !desktopArea) return;
        const areaRect = desktopArea.getBoundingClientRect();
        const bounds = getWindowBounds();
        const safeWidth = areaRect.width - bounds.leftInset - bounds.rightInset;
        const safeHeight = areaRect.height - bounds.topInset - bounds.bottomInset;

        const left = bounds.leftInset + Math.max(0, (safeWidth - windowEl.offsetWidth) / 2) + offset;
        const top = bounds.topInset + Math.max(0, (safeHeight - windowEl.offsetHeight) / 2) + offset;
        setWindowPosition(windowEl, left, top);
      };

      const setAdModalPosition = (left, top) => {
        if (!adModal) return;
        const bounds = getWindowBounds();
        const minLeft = bounds.leftInset;
        const minTop = bounds.topInset;
        const maxLeft = Math.max(minLeft, window.innerWidth - adModal.offsetWidth - bounds.rightInset);
        const maxTop = Math.max(minTop, window.innerHeight - adModal.offsetHeight - bounds.bottomInset);
        const clampedLeft = Math.min(Math.max(minLeft, left), maxLeft);
        const clampedTop = Math.min(Math.max(minTop, top), maxTop);

        adModal.style.left = `${clampedLeft}px`;
        adModal.style.top = `${clampedTop}px`;
      };

      const centerAdModal = () => {
        if (!adModal) return;
        const bounds = getWindowBounds();
        const safeWidth = window.innerWidth - bounds.leftInset - bounds.rightInset;
        const safeHeight = window.innerHeight - bounds.topInset - bounds.bottomInset;
        const left = bounds.leftInset + Math.max(0, (safeWidth - adModal.offsetWidth) / 2);
        const top = bounds.topInset + Math.max(0, (safeHeight - adModal.offsetHeight) / 2);
        setAdModalPosition(left, top);
      };

      const renderTaskbarButtons = () => {
        if (!taskbarWindows) return;

        const taskbarEntries = getOpenWindows().map((windowEl) => ({
          windowId: windowEl.dataset.window || '',
          taskLabel: windowEl.dataset.taskLabel || windowEl.getAttribute('aria-label') || windowEl.dataset.window || 'Ventana',
          isMinimized: windowEl.classList.contains('is-minimized'),
        }));

        if (isStartAdOpen()) {
          taskbarEntries.push({
            windowId: 'start-ad',
            taskLabel: 'Oferta',
            isMinimized: false,
          });
        }

        taskbarWindows.replaceChildren(
          ...taskbarEntries.map((entry) => {
            const button = document.createElement('button');

            button.type = 'button';
            button.className = 'taskbar-app';
            button.setAttribute('data-taskbar-app', entry.windowId);
            button.textContent = entry.taskLabel;

            if (entry.windowId === activeWindowId && !entry.isMinimized) {
              button.classList.add('is-active');
            }

            return button;
          })
        );
      };

      const focusTopVisibleWindow = () => {
        const topWindow = getTopVisibleWindow();
        if (!topWindow) {
          if (isStartAdOpen()) {
            activeWindowId = 'start-ad';
            renderTaskbarButtons();
            return;
          }

          activeWindowId = null;
          renderTaskbarButtons();
          return;
        }

        focusWindow(topWindow.dataset.window);
      };

      const focusWindow = (windowId) => {
        const windowEl = getWindowById(windowId);
        if (!windowEl) return;

        zCounter += 1;
        windowEl.style.zIndex = String(zCounter);
        activeWindowId = windowId;
        renderTaskbarButtons();
      };

      const showWindow = (windowId) => {
        const windowEl = getWindowById(windowId);
        if (!windowEl) return;
        const wasClosed = windowEl.classList.contains('is-closed');

        windowEl.classList.remove('is-closed');
        windowEl.classList.remove('is-minimized');

        if (wasClosed) {
          windowEl.classList.remove('is-maximized');
          centerWindow(windowEl);
        }

        focusWindow(windowId);
        if (windowId === 'projects') {
          window.requestAnimationFrame(() => {
            syncProjectsWindowSize();
          });
        }
        if (windowId === 'mines') {
          window.setTimeout(syncMinesWindowSize, 0);
        }
      };

      const hideWindow = (windowId) => {
        const windowEl = getWindowById(windowId);
        if (!windowEl) return;
        windowEl.classList.add('is-minimized');

        if (activeWindowId === windowId) {
          focusTopVisibleWindow();
        } else {
          renderTaskbarButtons();
        }
      };

      const closeWindow = (windowId) => {
        const windowEl = getWindowById(windowId);
        if (!windowEl) return;

        windowEl.classList.add('is-closed');
        windowEl.classList.remove('is-minimized');
        windowEl.classList.remove('is-maximized');

        if (activeWindowId === windowId) {
          focusTopVisibleWindow();
        } else {
          renderTaskbarButtons();
        }
      };

      const syncMinesWindowSize = () => {
        const minesWindow = getWindowById('mines');
        const minesApp = minesWindow?.querySelector('.mine-app');
        if (!minesWindow || !minesApp || !desktopArea) return;
        if (minesWindow.classList.contains('is-maximized')) return;

        const appRect = minesApp.getBoundingClientRect();
        const targetWidth = Math.ceil(appRect.width + 28);
        const targetHeight = Math.ceil(appRect.height + 64);
        minesWindow.style.width = `${targetWidth}px`;
        minesWindow.style.maxWidth = 'calc(100vw - 1rem)';
        minesWindow.style.minHeight = `${targetHeight}px`;

        const left = parseFloat(minesWindow.style.left || '0');
        const top = parseFloat(minesWindow.style.top || '0');
        setWindowPosition(minesWindow, left, top);
      };

      const syncProjectsWindowSize = () => {
        const projectsWindow = getWindowById('projects');
        const projectsContent = projectsWindow?.querySelector('.xp-window-content-projects');
        const projectsGrid = projectsWindow?.querySelector('.xp-window-grid');
        if (!projectsWindow || !projectsContent || !projectsGrid || !desktopArea) return;
        if (projectsWindow.classList.contains('is-closed') || projectsWindow.classList.contains('is-minimized')) return;

        if (projectsWindow.classList.contains('is-maximized')) {
          projectsWindow.style.height = '';
          projectsWindow.style.maxHeight = '';
          projectsContent.style.height = '';
          projectsContent.style.maxHeight = '';
          projectsContent.style.overflowX = 'hidden';
          projectsContent.style.overflowY = 'auto';
          return;
        }

        const areaRect = desktopArea.getBoundingClientRect();
        const bounds = getWindowBounds();
        const windowChromeHeight = projectsWindow.offsetHeight - projectsContent.offsetHeight;
        const contentStyles = window.getComputedStyle(projectsContent);
        const contentPaddingTop = parseFloat(contentStyles.paddingTop || '0');
        const contentPaddingBottom = parseFloat(contentStyles.paddingBottom || '0');
        const desiredContentHeight = Math.ceil(projectsGrid.scrollHeight + contentPaddingTop + contentPaddingBottom);
        const maxWindowHeight = Math.max(200, areaRect.height - bounds.topInset - bounds.bottomInset);
        const desiredWindowHeight = Math.min(maxWindowHeight, desiredContentHeight + windowChromeHeight);
        const resolvedContentHeight = Math.max(0, desiredWindowHeight - windowChromeHeight);
        const needsVerticalScroll = desiredContentHeight + windowChromeHeight > maxWindowHeight;

        projectsWindow.style.height = `${desiredWindowHeight}px`;
        projectsWindow.style.maxHeight = `${maxWindowHeight}px`;
        projectsContent.style.height = `${resolvedContentHeight}px`;
        projectsContent.style.maxHeight = `${resolvedContentHeight}px`;
        projectsContent.style.overflowX = 'hidden';
        projectsContent.style.overflowY = needsVerticalScroll ? 'auto' : 'visible';

        const left = parseFloat(projectsWindow.style.left || '0');
        const top = parseFloat(projectsWindow.style.top || '0');
        setWindowPosition(projectsWindow, left, top);
      };

      const showStartAd = () => {
        if (!startAd || !startButton || !adModal) return;
        startAd.hidden = false;
        startButton.setAttribute('aria-expanded', 'true');
        activeWindowId = 'start-ad';
        renderTaskbarButtons();
        window.requestAnimationFrame(() => {
          centerAdModal();
        });
      };

      const hideStartAd = () => {
        if (!startAd || !startButton) return;
        startAd.hidden = true;
        startButton.setAttribute('aria-expanded', 'false');

        if (activeWindowId === 'start-ad') {
          focusTopVisibleWindow();
        } else {
          renderTaskbarButtons();
        }
      };

      const setSelectedIcon = (selected) => {
        desktopIcons.forEach((icon) => icon.classList.remove('is-selected'));
        if (selected) selected.classList.add('is-selected');
      };

      windowEls.forEach((windowEl, index) => {
        windowEl.style.position = 'absolute';
        centerWindow(windowEl, index * 20);
      });

      showWindow('projects');
      closeWindow('mines');
      window.requestAnimationFrame(() => {
        syncProjectsWindowSize();
      });

      window.addEventListener('resize', () => {
        syncProjectsWindowSize();
        windowEls.forEach((windowEl) => {
          if (windowEl.classList.contains('is-maximized')) return;
          const left = parseFloat(windowEl.style.left || '0');
          const top = parseFloat(windowEl.style.top || '0');
          setWindowPosition(windowEl, left, top);
        });
        if (startAd && !startAd.hidden && adModal) {
          const left = parseFloat(adModal.style.left || '0');
          const top = parseFloat(adModal.style.top || '0');
          setAdModalPosition(left, top);
        }
        syncMinesWindowSize();
      });

      window.addEventListener('minesweeper:resize', () => {
        syncMinesWindowSize();
      });

      windowEls.forEach((windowEl) => {
        const titleBar = windowEl.querySelector('.xp-titlebar');
        const windowId = windowEl.dataset.window;

        if (!titleBar || !windowId) return;

        titleBar.addEventListener('pointerdown', (event) => {
          if (!(event.target instanceof Element)) return;
          if (event.target.closest('.xp-title-buttons')) return;
          if (windowEl.classList.contains('is-minimized') || windowEl.classList.contains('is-maximized')) return;

          focusWindow(windowId);
          dragState.active = true;
          dragState.windowId = windowId;
          dragState.pointerId = event.pointerId;

          const rect = windowEl.getBoundingClientRect();
          dragState.offsetX = event.clientX - rect.left;
          dragState.offsetY = event.clientY - rect.top;

          titleBar.setPointerCapture(event.pointerId);
          document.body.style.userSelect = 'none';
        });
      });

      window.addEventListener('pointermove', (event) => {
        if (!dragState.active || !dragState.windowId || !desktopArea) return;
        const windowEl = getWindowById(dragState.windowId);
        if (!windowEl || windowEl.classList.contains('is-maximized')) return;

        const areaRect = desktopArea.getBoundingClientRect();
        const left = event.clientX - areaRect.left - dragState.offsetX;
        const top = event.clientY - areaRect.top - dragState.offsetY;
        setWindowPosition(windowEl, left, top);
      });

      window.addEventListener('pointermove', (event) => {
        if (!adDragState.active || !adModal) return;

        const left = event.clientX - adDragState.offsetX;
        const top = event.clientY - adDragState.offsetY;
        setAdModalPosition(left, top);
      });

      window.addEventListener('pointerup', () => {
        dragState.active = false;
        dragState.windowId = null;
        dragState.pointerId = null;
        adDragState.active = false;
        adDragState.pointerId = null;
        document.body.style.userSelect = '';
      });

      adTitleBar?.addEventListener('pointerdown', (event) => {
        if (!adModal) return;
        if (!(event.target instanceof Element)) return;
        if (event.target.closest('.xp-title-buttons')) return;

        activeWindowId = 'start-ad';
        renderTaskbarButtons();
        adDragState.active = true;
        adDragState.pointerId = event.pointerId;

        const rect = adModal.getBoundingClientRect();
        adDragState.offsetX = event.clientX - rect.left;
        adDragState.offsetY = event.clientY - rect.top;

        adTitleBar.setPointerCapture(event.pointerId);
        document.body.style.userSelect = 'none';
      });

      windowEls.forEach((windowEl) => {
        const windowId = windowEl.dataset.window;
        if (!windowId) return;

        windowEl.addEventListener('pointerdown', () => {
          focusWindow(windowId);
        });

        const windowButtons = Array.from(windowEl.querySelectorAll('[data-win-action]'));

        windowButtons.forEach((button) => {
          button.addEventListener('click', () => {
            const action = button.getAttribute('data-win-action');

            if (action === 'min') {
              hideWindow(windowId);
              return;
            }

            if (action === 'max') {
              windowEl.classList.remove('is-minimized');
              windowEl.classList.toggle('is-maximized');

              if (!windowEl.classList.contains('is-maximized')) {
                centerWindow(windowEl);
              }

              if (windowId === 'projects') {
                window.requestAnimationFrame(() => {
                  syncProjectsWindowSize();
                });
              }

              focusWindow(windowId);
              return;
            }

            if (action === 'close') {
              closeWindow(windowId);
            }
          });
        });
      });

      openWindowButtons.forEach((button) => {
        button.addEventListener('click', (event) => {
          const targetWindow = button.getAttribute('data-open-window');
          if (!targetWindow) return;
          if (button.tagName === 'A') return;
          event.preventDefault();
          showWindow(targetWindow);
        });
      });

      desktopIcons.forEach((icon) => {
        icon.addEventListener('pointerdown', () => {
          setSelectedIcon(icon);
        });
      });

      taskbarWindows?.addEventListener('click', (event) => {
        const button = event.target instanceof Element ? event.target.closest('[data-taskbar-app]') : null;
        if (!button) return;

        const targetWindow = button.getAttribute('data-taskbar-app');
        if (!targetWindow) return;

        if (targetWindow === 'start-ad') {
          if (!isStartAdOpen()) {
            showStartAd();
            return;
          }

          if (activeWindowId === 'start-ad') {
            hideStartAd();
            return;
          }

          activeWindowId = 'start-ad';
          renderTaskbarButtons();
          return;
        }

        const windowEl = getWindowById(targetWindow);
        if (!windowEl || windowEl.classList.contains('is-closed')) return;

        if (windowEl.classList.contains('is-minimized')) {
          showWindow(targetWindow);
          return;
        }

        if (activeWindowId === targetWindow) {
          hideWindow(targetWindow);
          return;
        }

        focusWindow(targetWindow);
      });

      renderTaskbarButtons();

      startButton?.addEventListener('click', () => {
        showStartAd();
      });

      closeAdButton?.addEventListener('click', () => {
        hideStartAd();
      });

      closeAdOkButton?.addEventListener('click', () => {
        hideStartAd();
      });

      startAd?.addEventListener('click', (event) => {
        if (event.target === startAd) {
          hideStartAd();
        }
      });

      adImage?.addEventListener('load', () => {
        if (startAd && !startAd.hidden && !adDragState.active) {
          centerAdModal();
        }
      });

      const updateClock = () => {
        if (!clock) return;
        clock.textContent = new Date().toLocaleTimeString([], {
          hour: '2-digit',
          minute: '2-digit',
          second: '2-digit',
          hour12: true,
        });
      };

      updateClock();
      window.setInterval(updateClock, 1000);
      window.setTimeout(syncMinesWindowSize, 0);
      window.setTimeout(syncProjectsWindowSize, 0);
    });
  </script>
</BaseLayout>
