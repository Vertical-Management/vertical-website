---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import projects from '../data/projects.json';

const BASE_URL = import.meta.env.BASE_URL;
const basePrefix = BASE_URL.endsWith('/') ? BASE_URL : `${BASE_URL}/`;
const withBase = (path) => `${basePrefix}${path.replace(/^\/+/, '')}`;
const XP_FUN_ICONS = [
  'https://win98icons.alexmeub.com/icons/png/computer_explorer-5.png',
  'https://win98icons.alexmeub.com/icons/png/game_solitaire-0.png',
  'https://win98icons.alexmeub.com/icons/png/msie2-2.png',
  'https://win98icons.alexmeub.com/icons/png/world-0.png',
];
const XP_TITLE_ICON = 'https://upload.wikimedia.org/wikipedia/commons/5/59/OneDrive_Folder_Icon.png';
const XP_CLICK_SOUND = 'https://bit.ly/xp-click-sound';
---

<style is:global>
  html:has(.xp98-desktop),
  html:has(.xp98-desktop) body,
  html:has(.xp98-desktop) main {
    background: url('https://winxp.vercel.app/assets/bliss.jpg') center / cover no-repeat fixed;
  }
</style>

<BaseLayout title="Proyectos — Vertical Management">
  <div class="xp-desktop xp98-desktop">
    <Header />
    <div class="xp-window xp98-window">
      <div class="xp-title-bar xp98-title-bar">
        <div class="xp98-title-left">
          <img src={XP_TITLE_ICON} alt="" class="xp98-title-icon" />
          <span>Mis Proyectos</span>
        </div>
        <div class="xp-title-controls xp98-title-controls" aria-hidden="true">
          <button type="button" class="xp-btn xp98-btn xp98-btn-min" tabindex="-1">_</button>
          <button type="button" class="xp-btn xp98-btn xp98-btn-max" tabindex="-1">□</button>
          <button type="button" class="xp-btn xp98-btn xp98-btn-close" tabindex="-1">✕</button>
        </div>
      </div>
      <section class="projects vm-container xp98-content">
        <div class="project-grid xp98-grid">
          {projects.projects.map((p, idx) => (
            <div class="project-card xp98-item" key={p.slug}>
              <a href={withBase(`proyectos/${p.slug}`)}>
                <img
                  src={XP_FUN_ICONS[idx % XP_FUN_ICONS.length]}
                  alt={`Icono del proyecto ${p.title}`}
                  loading="lazy"
                  class="xp-folder-icon xp98-icon"
                />
                <h2 class="xp98-label">{p.title}</h2>
              </a>
            </div>
          ))}
        </div>
      </section>
    </div>
    <audio id="xp-click-audio" preload="auto" src={XP_CLICK_SOUND}></audio>
  </div>

  <script>
    document.addEventListener('DOMContentLoaded', () => {
      const cards = Array.from(document.querySelectorAll('.xp98-item'));
      const audio = document.getElementById('xp-click-audio');

      cards.forEach((card) => {
        const link = card.querySelector('a');
        if (!link) return;

        link.addEventListener('pointerdown', () => {
          cards.forEach((item) => item.classList.remove('is-selected'));
          card.classList.add('is-selected');
          if (audio) {
            audio.currentTime = 0;
            audio.play().catch(() => {});
          }
        });
      });
    });
  </script>
</BaseLayout>
