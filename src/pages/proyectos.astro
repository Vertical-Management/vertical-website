---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import projects from '../data/projects.json';

const BASE_URL = import.meta.env.BASE_URL;
const basePrefix = BASE_URL.endsWith('/') ? BASE_URL : `${BASE_URL}/`;
const withBase = (path) => `${basePrefix}${path.replace(/^\/+/, '')}`;
---
<BaseLayout title="Proyectos — Vertical Management">
  <Header />
  <section class="projects vm-container">
    <h1>Proyectos</h1>
    <div class="project-grid">
      {projects.projects.map((p) => (
        <article class="project-card" key={p.slug}>
          <a href={withBase(`proyectos/${p.slug}`)}>
            <img src={p.images?.[0] ? withBase(p.images[0]) : withBase('assets/placeholder.png')} alt={p.title} loading="eager" />
            <h2>{p.title}</h2>
            <p>{p.short}</p>
          </a>
        </article>
      ))}
    </div>
  </section>
</BaseLayout>
