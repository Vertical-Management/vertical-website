# Environment Configuration (Optional)

# GitHub Pages Settings
# If using a project repo, set this to '<username>.github.io/<repo-name>'
# If using user/org repo, leave empty
GITHUB_PAGES_REPO=

# Custom Domain (optional)
CUSTOM_DOMAIN=

# Analytics (optional)
# GOOGLE_ANALYTICS_ID=
# HOTJAR_ID=

# Contact Email (optional)
CONTACT_EMAIL=hello@example.com

# Social Media (optional)
SOCIAL_TWITTER=
SOCIAL_INSTAGRAM=
SOCIAL_LINKEDIN=

# Content Flags
SHOW_BLOG=false
SHOW_TESTIMONIALS=false
SHOW_FAQ=false
